# Application
APP_NAME=FamilyTreeAPI
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Regex cho phép các domain theo mẫu
APP_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# JWT / Auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB
MONGODB_URI= your_mongodb_uri mongodb://localhost:27017
MONGODB_DB=family_tree

# Neo4j
NEO4J_URI= your_neo4j_uri bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Email via Resend HTTPS API (DigitalOcean blocks outbound SMTP)
RESEND_API_KEY=re_your_api_key
# Verified domain on Resend, e.g. "no-reply@yourdomain.com".
EMAIL_FROM=onboarding@resend.dev

# Cloudinary (server-side image deletion).
CLOUDINARY_CLOUD_NAME= your_cloud_name
CLOUDINARY_API_KEY= your_api_key
CLOUDINARY_API_SECRET= your_api_secret